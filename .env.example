# ─────────────────────────────────────────────────────────────────────────────
# Tilthouse Discord Bot — Environment Configuration
# Copy this file to .env.development or .env.production and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node Environment ──────────────────────────────────────────────────────────
# Use "development" for your test server, "production" for the live server.
# Start with: NODE_ENV=development npm start
NODE_ENV=development

# ── Discord ───────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# The Application (client) ID from the Discord Developer Portal
CLIENT_ID=your_application_client_id_here

# The Guild (server) ID used for instant command updates in development.
# Only required when NODE_ENV=development.
GUILD_ID=your_test_guild_id_here

# ── YouTube Notifier ──────────────────────────────────────────────────────────
# Your YouTube Data API v3 key from https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# The YouTube channel ID to monitor (starts with UC…)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# The Discord channel ID where new-video notifications will be posted
YOUTUBE_DISCORD_CHANNEL_ID=000000000000000000

# (Optional) A Discord Role ID to ping when a new video is posted.
# Leave blank to use @here instead.
YOUTUBE_PING_ROLE=

# How often to poll YouTube for new videos, in milliseconds.
# Default: 600000 (10 minutes). Minimum recommended: 300000 (5 minutes).
YOUTUBE_POLL_INTERVAL_MS=600000

# ── Game Queue ────────────────────────────────────────────────────────────────
# Default number of players required to fill a queue and trigger a ping.
# Individual queues can override this with the /queue join threshold option.
QUEUE_PLAYER_THRESHOLD=5
