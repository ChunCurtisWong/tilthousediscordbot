logs/
*.log

# ── Node dependencies ─────────────────────────────────────────────────────────
node_modules/

# ── Runtime data (generated automatically at runtime) ────────────────────────
data/

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor artifacts ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
